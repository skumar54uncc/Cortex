    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4"
